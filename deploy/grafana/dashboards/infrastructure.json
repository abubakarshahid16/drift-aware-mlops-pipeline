{
  "title": "Infrastructure & API Health",
  "uid": "infra-health",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "tags": ["mlops", "infra"],
  "panels": [
    {
      "type": "stat",
      "title": "API uptime",
      "id": 1,
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "up{job=\"api\"}", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Drift monitor uptime",
      "id": 2,
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "up{job=\"drift_monitor\"}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "HTTP request rate",
      "id": 3,
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "targets": [{ "expr": "sum by (handler) (rate(http_requests_total[1m]))", "legendFormat": "{{handler}}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "HTTP request latency p95 (s)",
      "id": 4,
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le, handler) (rate(http_request_duration_seconds_bucket[1m])))",
        "legendFormat": "{{handler}}",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "HTTP errors (5xx)",
      "id": 5,
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 15 },
      "targets": [{ "expr": "sum by (status_code) (rate(http_requests_total{status_code=~\"5..\"}[1m]))", "legendFormat": "{{status_code}}", "refId": "A" }]
    }
  ]
}
