{
  "title": "Model Performance",
  "uid": "model-performance",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "tags": ["mlops", "model"],
  "panels": [
    {
      "type": "stat",
      "title": "Rolling Accuracy",
      "id": 1,
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "ml_rolling_accuracy", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 0.6 },
              { "color": "green",  "value": 0.75 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "type": "stat",
      "title": "Rolling Error Rate",
      "id": 2,
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "ml_rolling_error_rate", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.25 },
              { "color": "red", "value": 0.4 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Total Predictions",
      "id": 3,
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "sum(ml_predictions_total)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "type": "stat",
      "title": "Total Misclassifications",
      "id": 4,
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "ml_prediction_errors_total", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "type": "timeseries",
      "title": "Rolling Accuracy over time",
      "id": 5,
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 6 },
      "targets": [
        { "expr": "ml_rolling_accuracy", "legendFormat": "accuracy", "refId": "A" },
        { "expr": "ml_rolling_error_rate", "legendFormat": "error rate", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 }
      }
    },
    {
      "type": "timeseries",
      "title": "Predictions per second by class",
      "id": 6,
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 15 },
      "targets": [
        { "expr": "rate(ml_predictions_total[1m])", "legendFormat": "class {{predicted_label}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "type": "timeseries",
      "title": "Inference latency percentiles (s)",
      "id": 7,
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 15 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(ml_inference_latency_seconds_bucket[1m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(ml_inference_latency_seconds_bucket[1m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(ml_inference_latency_seconds_bucket[1m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
