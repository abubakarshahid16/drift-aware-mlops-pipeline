{
  "title": "Drift & Adaptive Retraining",
  "uid": "drift-monitoring",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["mlops", "drift"],
  "panels": [
    {
      "type": "stat",
      "title": "Drift events (5 min)",
      "id": 1,
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(increase(ml_drift_events_total[5m]))", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Total retrains",
      "id": 2,
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "sum(ml_retrains_total)", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Active model version",
      "id": 3,
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "ml_model_version_info", "refId": "A", "format": "table" }],
      "options": { "textMode": "name", "graphMode": "none" },
      "fieldConfig": { "defaults": { "noValue": "n/a" } }
    },
    {
      "type": "stat",
      "title": "Last drift severity",
      "id": 4,
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "max(ml_drift_severity)", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.25 },
              { "color": "red", "value": 0.40 }
            ]
          }
        }
      },
      "options": { "colorMode": "background" }
    },
    {
      "type": "timeseries",
      "title": "Drift events by detector",
      "id": 5,
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "sum by (detector) (increase(ml_drift_events_total[1m]))", "legendFormat": "{{detector}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Retraining triggers",
      "id": 6,
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "sum by (reason) (increase(ml_retrains_total[5m]))", "legendFormat": "{{reason}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Drift severity (live)",
      "id": 7,
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 15 },
      "targets": [
        { "expr": "ml_drift_severity", "legendFormat": "{{detector}}", "refId": "A" }
      ]
    }
  ]
}
